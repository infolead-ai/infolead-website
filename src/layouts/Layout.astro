---
interface Props {
	title?: string;
	lang?: 'en' | 'zh';
}
const { title = "InfoLead Technology", lang = "en" } = Astro.props;
---
<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:italic@0,1&family=Inter:wght@300;400;500;600&family=Noto+Sans+SC:wght@300;400;500&display=swap" rel="stylesheet">
	</head>
	<body>
		<div class="nebula-container"><div class="nebula purple"></div><div class="nebula cyan"></div></div>
		
		<nav>
			<div class="nav-content">
				<a href={lang === 'en' ? '/en/' : '/zh/'} class="logo">INFOLEAD</a>
				
				<button id="menu-btn" class="menu-btn" aria-label="Toggle Menu">
					<span></span><span></span><span></span>
				</button>

				<div class="nav-links" id="nav-links">
					<a href={lang === 'en' ? '/en/services' : '/zh/services'}>{lang === 'en' ? 'Services' : '服务'}</a>
					<a href={lang === 'en' ? '/en/about' : '/zh/about'}>{lang === 'en' ? 'About' : '关于'}</a>
					<a href={lang === 'en' ? '/zh/' : '/en/'} class="lang-btn">{lang === 'en' ? '中文' : 'EN'}</a>
					<a href={lang === 'en' ? '/en/contact' : '/zh/contact'} class="btn-mini">{lang === 'en' ? 'Contact' : '联系'}</a>
				</div>
			</div>
		</nav>
		
		<main><slot /></main>
		
		<footer>© {new Date().getFullYear()} InfoLead Technology Inc. · Toronto, Canada</footer>

		<script>
			const menuBtn = document.getElementById('menu-btn');
			const navLinks = document.getElementById('nav-links');
			
			menuBtn?.addEventListener('click', () => {
				menuBtn.classList.toggle('open');
				navLinks?.classList.toggle('active');
				// 打开菜单时禁止底层页面滚动
				document.body.style.overflow = navLinks?.classList.contains('active') ? 'hidden' : '';
			});
		</script>
	</body>
</html>

<style is:global>
	:root { --bg: #050714; --cyan: #00E5FF; --purple: #7C5CFF; --green: #C6FF4A; }
	
	html, body { margin: 0; background: var(--bg); color: #fff; font-family: 'Inter', 'Noto Sans SC', sans-serif; scroll-behavior: smooth; overflow-x: hidden; }
	
	.nebula-container { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; overflow: hidden; opacity: 0.3; pointer-events: none; }
	.nebula { position: absolute; width: 60vw; height: 60vw; filter: blur(120px); border-radius: 50%; }
	.purple { background: var(--purple); top: -20%; right: -10%; opacity: 0.4; }
	.cyan { background: var(--cyan); bottom: -20%; left: -10%; opacity: 0.3; }
	
	nav { padding: 24px 40px; position: fixed; width: 100%; box-sizing: border-box; z-index: 100; backdrop-filter: blur(12px); background: rgba(5,7,20,0.6); border-bottom: 1px solid rgba(255,255,255,0.05); top: 0; }
	.nav-content { max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
	.logo { font-weight: 600; letter-spacing: 2px; text-decoration: none; color: #fff; font-size: 1.2rem; position: relative; z-index: 101; }
	
	.menu-btn { display: none; background: none; border: none; cursor: pointer; flex-direction: column; gap: 6px; z-index: 101; padding: 4px; }
	.menu-btn span { display: block; width: 24px; height: 2px; background: #fff; transition: 0.3s ease; border-radius: 2px; }
	
	.nav-links { display: flex; gap: 32px; align-items: center; transition: 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); }
	.nav-links a { text-decoration: none; color: rgba(255,255,255,0.6); font-size: 14px; transition: 0.3s; }
	.nav-links a:hover { color: var(--cyan); }
	.lang-btn { border: 1px solid rgba(255,255,255,0.2); padding: 4px 10px; border-radius: 4px; font-family: monospace; }
	
	main { max-width: 1200px; margin: 0 auto; padding: 120px 40px 0; }
	.grad { background: linear-gradient(90deg, #fff, var(--cyan)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
	.italic { font-family: 'Instrument Serif', serif; font-style: italic; }
	footer { text-align: center; padding: 100px 20px 40px; font-size: 12px; color: rgba(255,255,255,0.3); font-family: monospace; }
	
	.btn { display: inline-flex; align-items: center; justify-content: center; text-decoration: none; border-radius: 99px; transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1); font-weight: 500; }
	.btn-primary { background: var(--cyan); color: #000; box-shadow: 0 0 20px rgba(0, 229, 255, 0.2); }
	.btn-primary:hover { transform: translateY(-3px); box-shadow: 0 0 30px rgba(0, 229, 255, 0.5); background: #33EEFF; }
	.btn-ghost { background: rgba(255, 255, 255, 0.03); color: #fff; border: 1px solid rgba(255, 255, 255, 0.1); }
	.btn-ghost:hover { background: rgba(255, 255, 255, 0.08); border-color: rgba(255, 255, 255, 0.3); transform: translateY(-3px); }
	.btn-mini { background: #fff; color: #000 !important; padding: 8px 20px; border-radius: 99px; font-weight: 600; transition: 0.3s; }
	.btn-mini:hover { background: var(--cyan); box-shadow: 0 0 15px rgba(0, 229, 255, 0.4); transform: translateY(-2px); }

	/* ==========================================================================
	   移动端响应式核心 (Mobile Responsive Core)
	   ========================================================================== */
	@media (max-width: 768px) {
		/* 收缩全局边距 */
		nav { padding: 16px 20px; }
		main { padding: 100px 20px 0; }
		
		/* 激活汉堡菜单按钮 */
		.menu-btn { display: flex; }
		
		/* 汉堡菜单动画：点击后变成 X */
		.menu-btn.open span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
		.menu-btn.open span:nth-child(2) { opacity: 0; }
		.menu-btn.open span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }

		/* 导航链接变身为全屏抽屉面板 */
		.nav-links {
			position: fixed;
			top: 0; right: -100%;
			width: 100vw; height: 100vh;
			background: rgba(5,7,20,0.98);
			backdrop-filter: blur(15px);
			flex-direction: column;
			justify-content: center;
			gap: 40px;
			padding: 0;
		}
		/* 抽屉弹出状态 */
		.nav-links.active { right: 0; }
		
		/* 移动端菜单文字放大，增强点击体验 */
		.nav-links a { font-size: 20px; color: #fff; }
		.btn-mini { padding: 12px 32px; font-size: 18px; }
	}
</style>