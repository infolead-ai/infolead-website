---
import Layout from '../layouts/Layout.astro';
import { services } from '../data/services';
---

<Layout title="Services — InfoLead AI Solutions">
  <section style="padding: 140px 0 80px; max-width: 900px;">
    <div class="tag" style="margin-bottom: 40px; display: inline-flex; align-items: center; gap: 12px; font-family: monospace; font-size: 11px; letter-spacing: 0.3em; color: rgba(255, 255, 255, 0.4); background: rgba(255, 255, 255, 0.03); padding: 8px 16px; border-radius: 999px; border: 1px solid rgba(255, 255, 255, 0.06);">
      <span class="dot" style="width: 6px; height: 6px; border-radius: 50%; background: #00E5FF; box-shadow: 0 0 12px rgba(0, 229, 255, 0.8);"></span>
      OUR EXPERTISE
    </div>
    
    <h1 class="italic" style="font-size: clamp(3rem, 7vw, 5rem); margin-bottom: 40px; line-height: 1;">
      Solutions engineered for <span class="grad">ROI.</span>
    </h1>
    
    <p style="font-size: 1.25rem; color: rgba(255,255,255,0.6); margin-bottom: 80px; line-height: 1.8;">
      我们不卖花哨的技术概念。我们的每一个 AI 解决方案，都直接指向为您削减人工成本，或带来新的高价值客户。
    </p>

    <div style="display: flex; flex-direction: column; gap: 100px;">
      {services.map((s) => (
        <div id={s.id} style="position: relative; padding-left: 40px; border-left: 1px solid rgba(255,255,255,0.1);">
          <div style="position: absolute; left: -6px; top: 0; width: 11px; height: 11px; background: #00E5FF; border-radius: 50%; box-shadow: 0 0 15px rgba(0, 229, 255, 0.5);"></div>
          
          <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 24px;">
            <span style="color: rgba(255,255,255,0.3); font-family: 'Instrument Serif', serif; font-size: 3rem; line-height: 1;">{s.id}</span>
            <h2 style="font-size: 2.2rem; font-weight: 500;">{s.title}</h2>
          </div>
          
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-bottom: 40px;">
            <div>
              <div style="color: #00E5FF; font-family: monospace; font-size: 11px; margin-bottom: 12px; letter-spacing: 0.1em;">BUSINESS VALUE (EN)</div>
              <p style="font-size: 1.1rem; color: rgba(255,255,255,0.6); line-height: 1.8;">{s.desc}</p>
            </div>
            <div>
              <div style="color: #00E5FF; font-family: monospace; font-size: 11px; margin-bottom: 12px; letter-spacing: 0.1em;">商业价值 (ZH)</div>
              <p style="font-size: 1.1rem; color: rgba(255,255,255,0.85); line-height: 1.8; font-family: 'Noto Sans SC', sans-serif;">{s.zhDesc}</p>
            </div>
          </div>

          <div style="display: flex; gap: 16px; flex-wrap: wrap;">
            {s.features.map(f => (
              <span style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.1); padding: 10px 24px; border-radius: 99px; font-size: 13px; color: rgba(255, 255, 255, 0.8); font-family: monospace;">{f}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div style="margin-top: 140px; text-align: center; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08); padding: 80px 40px; border-radius: 24px;">
      <h2 style="font-family: 'Instrument Serif', serif; font-size: 3rem; margin-bottom: 24px;">Ready to integrate AI?</h2>
      <p style="color: rgba(255,255,255,0.5); font-size: 1.1rem; margin-bottom: 40px; max-width: 500px; margin-left: auto; margin-right: auto;">
        告诉我们您的行业与痛点，我们将为您提供一份免费的 AI 投资回报率（ROI）评估报告。
      </p>
      <a href="/contact" class="btn btn-primary" style="padding: 16px 48px; font-size: 16px;">Schedule a Strategy Call →</a>
    </div>
  </section>
</Layout>