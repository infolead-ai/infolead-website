---
interface Props {
	title?: string;
	lang?: 'en' | 'zh';
}
const { title = "InfoLead Technology", lang = "en" } = Astro.props;
---
<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" /><meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:italic@0,1&family=Inter:wght@300;400;600&family=Noto+Sans+SC:wght@300;500&display=swap" rel="stylesheet">
	</head>
	<body>
		<div class="nebula-container"><div class="nebula purple"></div><div class="nebula cyan"></div></div>
		<nav>
			<div class="nav-content">
				<a href={lang === 'en' ? '/' : '/zh'} class="logo">INFOLEAD</a>
				<div class="nav-links">
					<a href={lang === 'en' ? '/services' : '/zh/services'}>{lang === 'en' ? 'Services' : '服务'}</a>
					<a href={lang === 'en' ? '/about' : '/zh/about'}>{lang === 'en' ? 'About' : '关于'}</a>
					<a href={lang === 'en' ? '/zh' : '/'} class="lang-btn">{lang === 'en' ? '中文' : 'EN'}</a>
					<a href={lang === 'en' ? '/contact' : '/zh/contact'} class="btn-mini">{lang === 'en' ? 'Contact' : '联系'}</a>
				</div>
			</div>
		</nav>
		<main><slot /></main>
		<footer>© {new Date().getFullYear()} InfoLead Technology Inc. · Toronto, Canada</footer>
	</body>
</html>

<style is:global>
	:root { --bg: #050505; --cyan: #00E5FF; --purple: #7C5CFF; }
	html, body { margin: 0; background: var(--bg); color: #fff; font-family: 'Inter', 'Noto Sans SC', sans-serif; }
	.nebula-container { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; overflow: hidden; opacity: 0.2; }
	.nebula { position: absolute; width: 50vw; height: 50vw; filter: blur(120px); border-radius: 50%; }
	.purple { background: var(--purple); top: -10%; right: -10%; }
	.cyan { background: var(--cyan); bottom: -10%; left: -10%; }
	nav { padding: 30px 40px; position: fixed; width: 100%; box-sizing: border-box; z-index: 10; backdrop-filter: blur(10px); }
	.nav-content { max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
	.logo { font-weight: 600; letter-spacing: 2px; text-decoration: none; color: #fff; }
	.nav-links { display: flex; gap: 30px; align-items: center; }
	.nav-links a { text-decoration: none; color: rgba(255,255,255,0.6); font-size: 14px; transition: 0.3s; }
	.nav-links a:hover { color: var(--cyan); }
	.lang-btn { border: 1px solid rgba(255,255,255,0.2); padding: 4px 10px; border-radius: 4px; }
	.btn-mini { background: #fff; color: #000 !important; padding: 8px 20px; border-radius: 99px; font-weight: 600; }
	main { max-width: 1200px; margin: 0 auto; padding: 120px 40px 0; }
	.grad { background: linear-gradient(90deg, #fff, var(--cyan)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
	.italic { font-family: 'Instrument Serif', serif; font-style: italic; }
	footer { text-align: center; padding: 100px 0 40px; font-size: 12px; color: rgba(255,255,255,0.3); }
</style>