---
import Layout from '../../../layouts/Layout.astro';
import AgentStage from '../../../components/demo/AgentStage.astro';
import LyraVoiceWidget from '../../../components/LyraVoiceWidget.tsx';
import { getMember } from '../../../data/ai-team';
import '../../../styles/demo-lyra.css';

export const prerender = true;

const lyra = getMember('lyra');
---

<Layout lang="en" title="Lyra · AI Brand Storyteller — InfoLead AI">
  <AgentStage agent={lyra} lang="en">
    <LyraVoiceWidget client:idle lang="en" variant="stage" />
  </AgentStage>
</Layout>
