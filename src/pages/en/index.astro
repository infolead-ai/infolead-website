---
import Layout from '../../layouts/Layout.astro';
import { services } from '../../data/services';
---

<Layout lang="en" title="InfoLead Technology — Premium AI Solutions for North America">
  
  <section style="padding: 140px 0 100px; position: relative;">
    <div class="tag" style="margin-bottom: 40px; display: inline-flex; align-items: center; gap: 12px; font-family: monospace; font-size: 11px; letter-spacing: 0.3em; color: rgba(255, 255, 255, 0.4); background: rgba(255, 255, 255, 0.03); padding: 8px 16px; border-radius: 999px; border: 1px solid rgba(255, 255, 255, 0.06);">
      <span class="dot" style="width: 6px; height: 6px; border-radius: 50%; background: #00E5FF; box-shadow: 0 0 12px rgba(0, 229, 255, 0.8);"></span>
      AI-NATIVE · TORONTO — CANADA
    </div>
    <h1 style="font-size: clamp(3.5rem, 8vw, 6rem); font-weight: 300; line-height: 0.95; margin-bottom: 40px; letter-spacing: -0.04em;">
      Scale Faster.<br/>
      <span class="grad">AI-Native</span> Solutions.
    </h1>
    <p style="font-size: 20px; color: rgba(255,255,255,0.6); max-width: 720px; margin-bottom: 56px; line-height: 1.6; font-weight: 300;">
      We bridge the gap between cutting-edge AI technology and real-world business results. From 24/7 voice agents to automated marketing engines, we build the systems that drive your growth while you focus on the vision.
    </p>
    <div class="cta" style="display: flex; gap: 20px; flex-wrap: wrap;">
      <a href="/en/contact" class="btn btn-primary" style="padding: 16px 36px; font-size: 15px;">Book a Strategy Call →</a>
      <a href="#industry" class="btn btn-ghost" style="padding: 16px 36px; font-size: 15px;">View Solutions</a>
    </div>
  </section>

  <div class="stats" style="display: flex; flex-wrap: wrap; gap: 60px; padding-top: 50px; border-top: 1px solid rgba(255,255,255,0.08); margin-bottom: 140px;">
    <div class="stat">
      <div style="font-size: 50px; font-family: 'Instrument Serif', serif; color: #F5F7FA; line-height: 1.1;">99.8%</div>
      <div style="font-family: monospace; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255, 255, 255, 0.4); margin-top: 4px;">Accuracy</div>
    </div>
    <div class="stat">
      <div style="font-size: 50px; font-family: 'Instrument Serif', serif; color: #F5F7FA; line-height: 1.1;">&lt;800ms</div>
      <div style="font-family: monospace; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255, 255, 255, 0.4); margin-top: 4px;">Voice Latency</div>
    </div>
    <div class="stat">
      <div style="font-size: 50px; font-family: 'Instrument Serif', serif; color: #F5F7FA; line-height: 1.1;">24/7</div>
      <div style="font-family: monospace; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255, 255, 255, 0.4); margin-top: 4px;">Always-On</div>
    </div>
  </div>

  <section id="process" style="margin-bottom: 140px;">
    <h2 style="font-family: 'Instrument Serif', serif; font-style: italic; font-size: clamp(2.5rem, 6vw, 3.8rem); font-weight: 400; margin-bottom: 60px;">The Delivery Process</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px; position: relative;">
      
      <div style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 20px; padding: 40px 30px; position: relative; z-index: 1;">
        <div style="width: 48px; height: 48px; border-radius: 50%; background: #050714; border: 1px solid #00E5FF; color: #00E5FF; display: flex; align-items: center; justify-content: center; font-family: monospace; font-size: 16px; margin-bottom: 24px; box-shadow: 0 0 20px rgba(0, 229, 255, 0.2);">01</div>
        <h3 style="font-size: 20px; margin-bottom: 12px; font-weight: 500;">AI Audit</h3>
        <p style="font-size: 14px; color: rgba(255, 255, 255, 0.55); line-height: 1.7;">Deep dive into your business bottlenecks. We identify exactly where AI can replace manual labor and generate the highest ROI.</p>
      </div>

      <div style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 20px; padding: 40px 30px; position: relative; z-index: 1;">
        <div style="width: 48px; height: 48px; border-radius: 50%; background: #050714; border: 1px solid #7C5CFF; color: #7C5CFF; display: flex; align-items: center; justify-content: center; font-family: monospace; font-size: 16px; margin-bottom: 24px; box-shadow: 0 0 20px rgba(124, 92, 255, 0.2);">02</div>
        <h3 style="font-size: 20px; margin-bottom: 12px; font-weight: 500;">Rapid Prototyping</h3>
        <p style="font-size: 14px; color: rgba(255, 255, 255, 0.55); line-height: 1.7;">Deploy a functional pilot within 7-14 days. We believe in showing, not telling. Test the AI with your real business data instantly.</p>
      </div>

      <div style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 20px; padding: 40px 30px; position: relative; z-index: 1;">
        <div style="width: 48px; height: 48px; border-radius: 50%; background: #050714; border: 1px solid #C6FF4A; color: #C6FF4A; display: flex; align-items: center; justify-content: center; font-family: monospace; font-size: 16px; margin-bottom: 24px; box-shadow: 0 0 20px rgba(198, 255, 74, 0.1);">03</div>
        <h3 style="font-size: 20px; margin-bottom: 12px; font-weight: 500;">Seamless Integration</h3>
        <p style="font-size: 14px; color: rgba(255, 255, 255, 0.55); line-height: 1.7;">Zero disruption to your current workflow. We integrate the AI agents directly into your existing CRM, VoIP, or scheduling tools.</p>
      </div>
    </div>
  </section>

  <section id="industry" style="margin-bottom: 140px;">
    <h2 style="font-family: 'Instrument Serif', serif; font-style: italic; font-size: clamp(2.5rem, 6vw, 3.8rem); font-weight: 400; margin-bottom: 60px;">Built for Your Industry</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 32px;">
      
      <div style="background: rgba(255, 255, 255, 0.01); border-top: 2px solid #7C5CFF; padding: 40px 30px; border-radius: 0 0 20px 20px; transition: 0.3s;" onmouseover="this.style.background='rgba(255, 255, 255, 0.03)'" onmouseout="this.style.background='rgba(255, 255, 255, 0.01)'">
        <div style="color: #7C5CFF; font-family: monospace; font-size: 12px; margin-bottom: 16px; letter-spacing: 0.1em;">LAW & ACCOUNTING</div>
        <h3 style="font-size: 24px; font-weight: 500; margin-bottom: 16px;">Law & Accounting Firms</h3>
        <p style="font-size: 15px; color: rgba(255,255,255,0.6); line-height: 1.8; margin-bottom: 24px;">
          The primary pain points are high labor costs and tedious compliance document retrieval. By deploying a <strong style="color: #F5F7FA; font-weight: 500;">Local Private Model (RAG)</strong>, junior staff can search past cases and tax regulations in seconds using natural language, drastically reducing non-billable hours.
        </p>
        <ul style="color: rgba(255,255,255,0.4); font-size: 14px; line-height: 2; list-style: none; padding: 0;">
          <li>✓ Automated PDF parsing & internal Q&A</li>
          <li>✓ Compliant data storage within Canada</li>
        </ul>
      </div>

      <div style="background: rgba(255, 255, 255, 0.01); border-top: 2px solid #00E5FF; padding: 40px 30px; border-radius: 0 0 20px 20px; transition: 0.3s;" onmouseover="this.style.background='rgba(255, 255, 255, 0.03)'" onmouseout="this.style.background='rgba(255, 255, 255, 0.01)'">
        <div style="color: #00E5FF; font-family: monospace; font-size: 12px; margin-bottom: 16px; letter-spacing: 0.1em;">REAL ESTATE BROKERAGES</div>
        <h3 style="font-size: 24px; font-weight: 500; margin-bottom: 16px;">Real Estate & Investment</h3>
        <p style="font-size: 15px; color: rgba(255,255,255,0.6); line-height: 1.8; margin-bottom: 24px;">
          Real estate transactions are a race against time. We build a <strong style="color: #F5F7FA; font-weight: 500;">24/7 Bilingual AI Voice Assistant</strong> that responds to buyer inquiries instantly, even late at night. Paired with our <strong style="color: #F5F7FA; font-weight: 500;">Automation Engine</strong>, we generate traffic-driving content for your social media matrix.
        </p>
        <ul style="color: rgba(255,255,255,0.4); font-size: 14px; line-height: 2; list-style: none; padding: 0;">
          <li>✓ 24/7 pre-construction inquiries & lead qualification</li>
          <li>✓ Automated marketing for social media</li>
        </ul>
      </div>

      <div style="background: rgba(255, 255, 255, 0.01); border-top: 2px solid #C6FF4A; padding: 40px 30px; border-radius: 0 0 20px 20px; transition: 0.3s;" onmouseover="this.style.background='rgba(255, 255, 255, 0.03)'" onmouseout="this.style.background='rgba(255, 255, 255, 0.01)'">
        <div style="color: #C6FF4A; font-family: monospace; font-size: 12px; margin-bottom: 16px; letter-spacing: 0.1em;">PREMIUM LOCAL SERVICES</div>
        <h3 style="font-size: 24px; font-weight: 500; margin-bottom: 16px;">Clinics & Auto Shops</h3>
        <p style="font-size: 15px; color: rgba(255,255,255,0.6); line-height: 1.8; margin-bottom: 24px;">
          Your front desk should focus on welcoming VIP clients, not answering endless calls for quotes and directions. We build the perfect <strong style="color: #F5F7FA; font-weight: 500;">Automated Customer Funnel</strong> using AI, seamlessly integrated with booking systems like Jane App.
        </p>
        <ul style="color: rgba(255,255,255,0.4); font-size: 14px; line-height: 2; list-style: none; padding: 0;">
          <li>✓ Zero-wait bilingual answering & auto-scheduling</li>
          <li>✓ Cross-cultural localization & automated follow-ups</li>
        </ul>
      </div>

    </div>
  </section>

  <section id="services" class="services" style="margin-bottom: 140px;">
    <h2 style="font-family: 'Instrument Serif', serif; font-style: italic; font-size: clamp(2.5rem, 6vw, 3.8rem); font-weight: 400; margin-bottom: 60px;">Core AI Solutions</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 24px;">
      {services.map((s) => (
        <a href={`/en/services#${s.id}`} style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 24px; padding: 40px; text-decoration: none; color: inherit; transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); position: relative; overflow: hidden; display: block;" onmouseover="this.style.borderColor='rgba(0, 229, 255, 0.4)'; this.style.transform='translateY(-6px)'; this.style.background='rgba(255, 255, 255, 0.05)'" onmouseout="this.style.borderColor='rgba(255, 255, 255, 0.06)'; this.style.transform='translateY(0)'; this.style.background='rgba(255, 255, 255, 0.02)'">
          <div style="font-family: monospace; font-size: 11px; color: #00E5FF; margin-bottom: 24px; letter-spacing: 0.1em;">SOL-{s.id}</div>
          <h3 style="font-size: 24px; font-weight: 500; margin-bottom: 16px;">{s.title}</h3>
          <p style="font-size: 15px; color: rgba(255, 255, 255, 0.55); line-height: 1.8; font-weight: 300;">{s.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <section id="pilot" style="margin-bottom: 100px;">
    <div style="background: linear-gradient(135deg, rgba(10, 15, 31, 0.8) 0%, rgba(5, 7, 20, 0.9) 100%); border: 1px solid rgba(0, 229, 255, 0.2); border-radius: 24px; padding: 60px 40px; position: relative; overflow: hidden; box-shadow: inset 0 0 40px rgba(0, 229, 255, 0.05);">
      <div style="position: absolute; top: -50px; right: -50px; width: 200px; height: 200px; background: #7C5CFF; filter: blur(100px); opacity: 0.15; border-radius: 50%;"></div>
      
      <div style="display: flex; flex-wrap: wrap; gap: 40px; align-items: center; position: relative; z-index: 1;">
        <div style="flex: 1; min-width: 300px;">
          <div style="font-family: monospace; font-size: 12px; color: #00E5FF; margin-bottom: 16px; letter-spacing: 0.1em;">PILOT SHOWCASE</div>
          <h2 style="font-size: 36px; font-weight: 500; margin-bottom: 20px;">Aplus Sport Club</h2>
          <p style="font-size: 16px; color: rgba(255, 255, 255, 0.6); line-height: 1.8; margin-bottom: 30px;">
            Among premium sports clubs in the Greater Toronto Area, Aplus is taking the lead in implementing our AI voice reception system. Through our integration, the club can:
          </p>
          <ul style="color: rgba(255, 255, 255, 0.6); line-height: 2.2; margin-bottom: 40px; font-size: 15px; list-style: none; padding: 0;">
            <li>✓ Answer booking calls 24/7 in English & Mandarin seamlessly</li>
            <li>✓ Auto-sync directly with existing Mindbody/Jane scheduling systems</li>
            <li>✓ Save approximately <strong style="color: #C6FF4A;">$45,000</strong> annually in labor costs</li>
          </ul>
          <a href="/en/contact" class="btn btn-primary" style="padding: 14px 30px;">Implement this for my business →</a>
        </div>
        
        <div style="flex: 1; min-width: 300px; background: rgba(0, 0, 0, 0.5); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 16px; padding: 28px; font-family: monospace; font-size: 13px; color: rgba(255, 255, 255, 0.5);">
          <div style="display: flex; gap: 8px; margin-bottom: 20px;">
            <div style="width: 10px; height: 10px; border-radius: 50%; background: #FF5F56;"></div>
            <div style="width: 10px; height: 10px; border-radius: 50%; background: #FFBD2E;"></div>
            <div style="width: 10px; height: 10px; border-radius: 50%; background: #27C93F;"></div>
          </div>
          <div style="color: #00E5FF; margin-bottom: 12px;">// INF-CORE-01 LOG ACTIVE</div>
          <div style="color: #888; margin-bottom: 8px;">[14:22:01] Inbound call detected: +1 (647) ***-****</div>
          <div style="color: #888; margin-bottom: 8px;">[14:22:02] Language ID: Mandarin (CN)</div>
          <div style="color: #C6FF4A; margin-bottom: 8px;">[14:22:03] AI Receptionist: "您好，这里是 Aplus 体育俱乐部，请问需要帮您预约明天的羽毛球场地吗？"</div>
          <div style="color: #888; margin-bottom: 8px;">[14:22:15] Customer: "是的，想订下午三点的两号场。"</div>
          <div style="color: #7C5CFF; margin-bottom: 8px;">[14:22:17] API Hook: Checking calendar availability...</div>
          <div style="color: #27C93F; margin-bottom: 20px;">[14:22:18] Success: Court 2 booked for 3PM Tomorrow.</div>
          <div style="color: #00E5FF;">_ SESSION COMPLETE _</div>
        </div>
      </div>
    </div>
  </section>

</Layout>