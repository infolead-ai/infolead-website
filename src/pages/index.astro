---
import Layout from '../layouts/Layout.astro';
import { services } from '../data/services';
---

<Layout title="InfoLead Technology — Premium AI Solutions for North America">
  
  <section style="padding: 140px 0 100px;">
    <div class="tag" style="margin-bottom: 40px; display: inline-flex; align-items: center; gap: 12px; font-family: monospace; font-size: 11px; letter-spacing: 0.3em; color: rgba(255, 255, 255, 0.4); background: rgba(255, 255, 255, 0.03); padding: 8px 16px; border-radius: 999px; border: 1px solid rgba(255, 255, 255, 0.06);">
      <span class="dot" style="width: 6px; height: 6px; border-radius: 50%; background: #00E5FF; box-shadow: 0 0 12px rgba(0, 229, 255, 0.8);"></span>
      AI-NATIVE · TORONTO — CANADA
    </div>
    <h1 style="font-size: clamp(3.5rem, 9vw, 6rem); font-weight: 300; line-height: 0.9; margin-bottom: 48px; letter-spacing: -0.05em;">
      Scale Faster.<br/>
      <span class="grad">AI-Native</span> Solutions.
    </h1>
    <p style="font-size: 22px; color: rgba(255,255,255,0.6); max-width: 720px; margin-bottom: 64px; line-height: 1.6; font-weight: 300;">
      We bridge the gap between cutting-edge AI technology and real-world business results. From 24/7 voice agents to automated marketing engines, we build the systems that drive your growth while you focus on the vision.
    </p>
    <div class="cta" style="display: flex; gap: 24px; flex-wrap: wrap;">
      <a href="/contact" class="btn btn-primary" style="padding: 18px 40px; font-size: 16px;">Get a Tailored Quote →</a>
      <a href="#pilot" class="btn btn-ghost" style="padding: 18px 40px; font-size: 16px;">View Case Study</a>
    </div>
  </section>

  <section style="margin-bottom: 160px;">
    <h2 class="italic" style="font-size: 42px; margin-bottom: 60px;">Why InfoLead?</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 40px;">
      <div>
        <h4 style="color: #00E5FF; margin-bottom: 12px; font-family: monospace;">[ Bilingual Mastery ]</h4>
        <p style="color: rgba(255,255,255,0.5); font-size: 14px;">我们深度理解中英双语商业语境，不仅提供技术，更提供能够精准触达北美华人与西人市场的文案与沟通策略。</p>
      </div>
      <div>
        <h4 style="color: #7C5CFF; margin-bottom: 12px; font-family: monospace;">[ Rapid Deployment ]</h4>
        <p style="color: rgba(255,255,255,0.5); font-size: 14px;">告别动辄数月的传统外包。利用 AI 原生开发流，我们在 7-14 天内即可交付可运行的试点项目。</p>
      </div>
      <div>
        <h4 style="color: #C6FF4A; margin-bottom: 12px; font-family: monospace;">[ Local Compliance ]</h4>
        <p style="color: rgba(255,255,255,0.5); font-size: 14px;">作为加拿大公司，我们严格遵守北美数据隐私与电信合规标准，保障您的业务数据安全资产。</p>
      </div>
    </div>
  </section>

  <section id="services" style="margin-bottom: 160px;">
    <h2 style="font-family: serif; font-style: italic; font-size: 48px; margin-bottom: 60px;">Comprehensive Solutions</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 32px;">
      {services.map((s) => (
        <a href={`/services#${s.id}`} class="service-card" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 24px; padding: 48px; text-decoration: none; color: inherit; transition: 0.4s; display: block;" onmouseover="this.style.borderColor='rgba(0,229,255,0.4)'; this.style.transform='translateY(-8px)'; this.style.background='rgba(255,255,255,0.04)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.06)'; this.style.transform='translateY(0)'; this.style.background='rgba(255,255,255,0.02)'">
          <div style="color: #00E5FF; font-family: monospace; font-size: 12px; margin-bottom: 24px;">SOL-{s.id}</div>
          <h3 style="font-size: 26px; margin-bottom: 12px;">{s.title}</h3>
          <div style="font-size: 14px; color: rgba(0, 229, 255, 0.6); margin-bottom: 24px; font-family: sans-serif;">{s.zh}</div>
          <p style="font-size: 15px; color: rgba(255,255,255,0.5); line-height: 1.8;">{s.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <section id="pilot" style="margin-bottom: 140px;">
    <div style="background: linear-gradient(135deg, rgba(10, 15, 31, 1) 0%, rgba(5, 7, 20, 1) 100%); border: 1px solid rgba(0, 229, 255, 0.25); border-radius: 32px; padding: 80px 60px; position: relative; overflow: hidden;">
      <div style="position: absolute; top: 0; right: 0; width: 300px; height: 300px; background: #7C5CFF; filter: blur(150px); opacity: 0.1;"></div>
      
      <div style="display: flex; flex-wrap: wrap; gap: 60px; align-items: center;">
        <div style="flex: 1; min-width: 320px;">
          <div style="color: #00E5FF; font-family: monospace; font-size: 12px; margin-bottom: 20px; letter-spacing: 0.2em;">PILOT SHOWCASE</div>
          <h2 style="font-size: 42px; font-weight: 500; margin-bottom: 24px;">Aplus Sport Club</h2>
          <p style="font-size: 18px; color: rgba(255, 255, 255, 0.7); line-height: 1.8; margin-bottom: 32px;">
            在大多伦多地区的高端体育俱乐部中，Aplus 正在率先实施我们的 AI 语音接待系统。通过我们的集成，该俱乐部能够：
          </p>
          <ul style="color: rgba(255, 255, 255, 0.5); line-height: 2.2; margin-bottom: 40px; font-size: 16px;">
            <li>✓ 24/7 接听中英双语预约电话，漏接率为零</li>
            <li>✓ 自动同步现有的 Mindbody/Jane 排课系统</li>
            <li>✓ 每年节省约 $45,000 的前台人力支出</li>
          </ul>
          <a href="/contact" class="btn btn-primary">Implement this for my business →</a>
        </div>
        
        <div style="flex: 1; min-width: 320px; background: #000; border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 20px; padding: 32px; font-family: monospace; font-size: 13px;">
            <div style="color: #00E5FF; margin-bottom: 12px;">// INF-CORE-01 LOG ACTIVE</div>
            <div style="color: #888;">[14:22:01] Inbound call detected: +1 (647) ***-****</div>
            <div style="color: #888;">[14:22:02] Language identification: Mandarin (CN)</div>
            <div style="color: #C6FF4A;">[14:22:03] AI Receptionist: "您好，这里是 Aplus 体育俱乐部，请问需要帮您预约明天的羽毛球场地吗？"</div>
            <div style="color: #888;">[14:22:15] Customer: "是的，想订下午三点的两号场。"</div>
            <div style="color: #7C5CFF;">[14:22:17] API Hook: Checking calendar availability...</div>
            <div style="color: #27C93F;">[14:22:18] Success: Court 2 booked for 3PM Tomorrow.</div>
            <div style="color: #00E5FF; margin-top: 20px;">_ SESSION COMPLETE _</div>
        </div>
      </div>
    </div>
  </section>

</Layout>