---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About — InfoLead Technology">
  <section style="padding: 120px 0; max-width: 800px;">
    <h1 class="italic" style="font-size: 4rem; margin-bottom: 60px;">The InfoLead Story</h1>
    <p style="font-size: 1.25rem; line-height: 1.8; margin-bottom: 40px;">
      InfoLead Technology Inc. 是一家位于加拿大多伦多的联邦注册 AI 服务公司。我们致力于为北美华人中小企业提供极速、合规且具有极致审美竞争力的 AI 解决方案。
    </p>
    <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.1); padding: 40px; border-radius: 20px;">
      <h3 style="margin-bottom: 20px;">Why InfoLead?</h3>
      <ul style="color: rgba(255,255,255,0.6); line-height: 2;">
        <li>联邦级合规背书 (Registered Federal Corporation)</li>
        <li>深度理解中英双语商业语境</li>
        <li>本地化数据安全保障 (Canada/USA Data Residency)</li>
        <li>承接从“想法”到“真实上线”的全链路交付</li>
      </ul>
    </div>
  </section>
</Layout>