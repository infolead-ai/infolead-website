---
import Layout from '../../layouts/Layout.astro';

export const prerender = true;
---

<Layout lang="en" title="Our Standards — InfoLead Quality Protocol">

  <!-- HERO -->
  <section style="padding: 80px 0 60px; text-align: center;">
    <div style="display: inline-flex; align-items: center; gap: 12px; font-family: monospace; font-size: 11px; letter-spacing: 0.3em; color: rgba(255, 255, 255, 0.4); background: rgba(255, 255, 255, 0.03); padding: 8px 16px; border-radius: 999px; border: 1px solid rgba(255, 255, 255, 0.06); margin-bottom: 32px;">
      <span style="width: 6px; height: 6px; border-radius: 50%; background: #00E5FF; box-shadow: 0 0 12px rgba(0, 229, 255, 0.8);"></span>
      AI · CERTIFIED · TORONTO · CANADA
    </div>
    <h1 style="font-size: clamp(2.8rem, 6.5vw, 4.2rem); font-weight: 300; line-height: 1.05; margin-bottom: 24px; letter-spacing: -0.03em;">
      The InfoLead <span class="grad">Quality Standard</span>
    </h1>
    <p style="font-size: 18px; color: rgba(255,255,255,0.6); max-width: 560px; margin: 0 auto; line-height: 1.6; font-weight: 300;">
      Every deployment. Every update. Every client.
    </p>
  </section>

  <!-- SECTION 1: The Number -->
  <section style="padding: 60px 0 80px; text-align: center; border-top: 1px solid rgba(255,255,255,0.06); border-bottom: 1px solid rgba(255,255,255,0.06);">
    <div style="font-family: 'Instrument Serif', serif; font-style: italic; font-size: clamp(8rem, 22vw, 16rem); color: #00E5FF; line-height: 0.9; text-shadow: 0 0 60px rgba(0,229,255,0.25); margin-bottom: 16px;">17</div>
    <div style="font-family: monospace; font-size: 11px; letter-spacing: 0.25em; color: rgba(255,255,255,0.5); margin-bottom: 40px;">AUTOMATED QA CHECKS BEFORE EVERY DEPLOYMENT</div>
    <p style="font-size: 17px; color: rgba(255,255,255,0.65); max-width: 540px; margin: 0 auto; line-height: 1.7; font-weight: 300;">
      Most AI vendors ship fast and fix later.<br/>
      <span style="color: #fff;">We fix before we ship.</span>
    </p>
  </section>

  <!-- SECTION 2: Four Categories -->
  <section style="padding: 100px 0;">
    <h2 style="font-family: 'Instrument Serif', serif; font-style: italic; font-size: clamp(2.2rem, 5vw, 3.2rem); font-weight: 400; margin-bottom: 60px; text-align: center;">Four Pillars of Trust</h2>
    <div class="standards-grid">

      <div class="standard-card" style="border-top-color: #FF5050;">
        <div class="standard-icon">🛡️</div>
        <div class="standard-eyebrow" style="color: #FF5050;">SECURITY</div>
        <h3>Security</h3>
        <ul>
          <li>Prompt injection defense</li>
          <li>System prompt confidentiality</li>
          <li>Identity protection</li>
          <li>Adversarial input handling</li>
        </ul>
      </div>

      <div class="standard-card" style="border-top-color: #FF9500;">
        <div class="standard-icon">🎯</div>
        <div class="standard-eyebrow" style="color: #FF9500;">ACCURACY</div>
        <h3>Accuracy</h3>
        <ul>
          <li>No fabricated statistics</li>
          <li>No invented client references</li>
          <li>No unconfirmed integrations</li>
          <li>Honest capability limits</li>
        </ul>
      </div>

      <div class="standard-card" style="border-top-color: #34C759;">
        <div class="standard-icon">✓</div>
        <div class="standard-eyebrow" style="color: #34C759;">COMPLIANCE</div>
        <h3>Compliance</h3>
        <ul>
          <li>Pricing guardrails enforced</li>
          <li>Price confirmation blocked</li>
          <li>Brand-safe responses only</li>
        </ul>
      </div>

      <div class="standard-card" style="border-top-color: #00E5FF;">
        <div class="standard-icon">⚡</div>
        <div class="standard-eyebrow" style="color: #00E5FF;">RESILIENCE</div>
        <h3>Resilience</h3>
        <ul>
          <li>Rate limiting (10 req/min/IP)</li>
          <li>Message length cap (1000 chars)</li>
          <li>Session limit (20 messages)</li>
          <li>Malformed input handling</li>
          <li>Off-topic redirect working</li>
          <li>Empty input rejected</li>
        </ul>
      </div>

    </div>
  </section>

  <!-- SECTION 3: Real Story -->
  <section style="padding: 60px 0 100px;">
    <div class="real-story">
      <div class="real-story-eyebrow">CASE FILE · 2026-04-26</div>
      <h2>We found 3 critical issues in our own demo.</h2>
      <p style="margin-bottom: 28px;">
        Before opening our AI demo to the public, we ran our full QA protocol and discovered:
      </p>

      <div class="finding">
        <div class="finding-tag" style="color: #FF5050;">🔴 P0 — Prompt injection vulnerability</div>
        <p>Our AI would reveal its entire system prompt if asked to. <strong>Fixed before launch.</strong></p>
      </div>

      <div class="finding">
        <div class="finding-tag" style="color: #FF9500;">🟠 P1 — Data fabrication</div>
        <p>The AI invented a client case study and a "60% cost-saving" statistic. <strong>Both removed.</strong></p>
      </div>

      <div class="finding">
        <div class="finding-tag" style="color: #FF9500;">🟠 P1 — Phantom client references</div>
        <p>The AI claimed existing law firm partnerships that don't exist. <strong>Guardrails added.</strong></p>
      </div>

      <p style="margin-top: 32px; font-size: 15px; color: rgba(255,255,255,0.55);">
        We fixed all three. Then ran 17 tests to confirm. Then opened the demo.
      </p>
    </div>
  </section>

  <!-- SECTION 4: Promise -->
  <section style="padding: 80px 0 60px; text-align: center;">
    <div style="font-family: 'Instrument Serif', serif; font-style: italic; font-size: clamp(2.8rem, 7vw, 5rem); line-height: 1.05; letter-spacing: -0.02em;">
      <div style="color: rgba(255,255,255,0.5);">If it doesn't pass,</div>
      <div class="grad" style="margin-top: 8px;">it doesn't ship.</div>
    </div>
    <div style="margin-top: 56px; font-family: monospace; font-size: 12px; letter-spacing: 0.15em; color: rgba(255,255,255,0.4); line-height: 1.8;">
      — GLEN TANG, FOUNDER<br/>
      &nbsp;&nbsp;INFOLEAD TECHNOLOGY INC.
    </div>
  </section>

  <!-- CTA -->
  <section style="padding: 40px 0 100px; text-align: center;">
    <div class="flex gap-5 flex-wrap" style="justify-content: center;">
      <a href="/en/demo" class="btn btn-primary" style="padding: 16px 36px; font-size: 15px;">Try the Demo →</a>
      <a href="mailto:hello@infolead.ca" class="btn btn-ghost" style="padding: 16px 36px; font-size: 15px;">Book a Strategy Call →</a>
    </div>
  </section>

</Layout>

<style>
  .standards-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
  }
  @media (max-width: 720px) {
    .standards-grid { grid-template-columns: 1fr; gap: 20px; }
  }

  .standard-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-top: 3px solid;
    border-radius: 18px;
    padding: 36px 30px;
    transition: 0.3s;
  }
  .standard-card:hover {
    background: rgba(255, 255, 255, 0.04);
    transform: translateY(-3px);
  }
  .standard-icon {
    font-size: 32px;
    margin-bottom: 16px;
    line-height: 1;
  }
  .standard-eyebrow {
    font-family: monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    margin-bottom: 12px;
  }
  .standard-card h3 {
    font-size: 24px;
    font-weight: 500;
    margin: 0 0 20px 0;
    color: #fff;
  }
  .standard-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
    color: rgba(255,255,255,0.65);
    font-size: 14px;
    line-height: 2;
  }
  .standard-card li::before {
    content: "→";
    color: rgba(255,255,255,0.3);
    margin-right: 10px;
  }

  .real-story {
    background: linear-gradient(135deg, rgba(0, 0, 0, 0.5), rgba(10, 14, 26, 0.7));
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-left: 3px solid #00E5FF;
    border-radius: 0 18px 18px 0;
    padding: 48px 44px;
    max-width: 840px;
    margin: 0 auto;
  }
  @media (max-width: 720px) {
    .real-story { padding: 32px 24px; }
  }
  .real-story-eyebrow {
    font-family: monospace;
    font-size: 11px;
    letter-spacing: 0.25em;
    color: rgba(0, 229, 255, 0.7);
    margin-bottom: 20px;
  }
  .real-story h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    font-weight: 500;
    margin: 0 0 28px 0;
    line-height: 1.25;
    color: #fff;
  }
  .real-story p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 15.5px;
    line-height: 1.75;
    margin: 0 0 16px 0;
  }
  .finding {
    margin: 28px 0;
    padding-left: 16px;
    border-left: 2px solid rgba(255, 255, 255, 0.08);
  }
  .finding-tag {
    font-family: monospace;
    font-size: 12.5px;
    letter-spacing: 0.05em;
    margin-bottom: 6px;
    font-weight: 600;
  }
  .finding p {
    margin: 4px 0 0 0;
    font-size: 15px;
  }
  .finding strong { color: #34C759; font-weight: 500; }
  .real-story p, .finding p { font-family: 'JetBrains Mono', 'IBM Plex Mono', ui-monospace, monospace; font-size: 14px; }
</style>
