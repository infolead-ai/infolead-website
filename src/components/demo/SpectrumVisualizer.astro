---
import type { TeamMember } from '../../data/ai-team';

interface Props {
  agent: TeamMember;
}
const { agent } = Astro.props;
---

<div class="spectrum" aria-hidden="true">
  <canvas
    class="spectrum__canvas"
    data-spectrum
    data-color-bottom={agent.primaryColor}
    data-color-top={agent.secondaryColor ?? agent.primaryColor}
  ></canvas>
</div>

<script>
  type Cfg = { bars: number; fps: number };

  function isWeChat(): boolean {
    return /MicroMessenger/i.test(navigator.userAgent || '');
  }

  function pickConfig(): Cfg {
    if (isWeChat()) return { bars: 32, fps: 30 };
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      return { bars: 32, fps: 12 };
    }
    return { bars: 64, fps: 60 };
  }

  function resize(canvas: HTMLCanvasElement) {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const rect = canvas.getBoundingClientRect();
    canvas.width = Math.max(1, Math.floor(rect.width * dpr));
    canvas.height = Math.max(1, Math.floor(rect.height * dpr));
    return dpr;
  }

  function readAmplitude(stage: HTMLElement | null): number {
    if (!stage) return 0;
    const v = getComputedStyle(stage).getPropertyValue('--lyra-amp').trim();
    if (!v) return 0;
    const n = parseFloat(v);
    return Number.isFinite(n) ? Math.max(0, Math.min(1, n)) : 0;
  }

  function init() {
    document.querySelectorAll<HTMLCanvasElement>('canvas[data-spectrum]').forEach((canvas) => {
      const stage = canvas.closest<HTMLElement>('.agent-stage');
      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      const cfg = pickConfig();
      const colorBottom = canvas.dataset.colorBottom || '#A78BFA';
      const colorTop = canvas.dataset.colorTop || '#FFD700';

      let dpr = resize(canvas);
      const onResize = () => { dpr = resize(canvas); };
      window.addEventListener('resize', onResize, { passive: true });

      const phases = new Float32Array(cfg.bars);
      for (let i = 0; i < cfg.bars; i++) phases[i] = Math.random() * Math.PI * 2;

      const minFrameMs = 1000 / cfg.fps;
      let lastDraw = 0;
      let rafId = 0;
      let running = false;

      function frame(now: number) {
        if (!running) return;
        if (now - lastDraw < minFrameMs) {
          rafId = requestAnimationFrame(frame);
          return;
        }
        lastDraw = now;
        const w = canvas.width;
        const h = canvas.height;
        ctx.clearRect(0, 0, w, h);

        const amp = readAmplitude(stage);
        const idle = 0.18;
        const drive = idle + (1 - idle) * amp;

        const gap = 2 * dpr;
        const barW = (w - gap * (cfg.bars + 1)) / cfg.bars;
        const baseY = h;
        const t = now / 1000;

        for (let i = 0; i < cfg.bars; i++) {
          const phase = phases[i] + t * (1.2 + (i % 5) * 0.18);
          const wave = (Math.sin(phase) + 1) / 2;
          const noise = Math.random() * 0.15;
          const norm = (wave * 0.7 + noise * 0.3) * drive;
          const barH = Math.max(2 * dpr, norm * h * 0.92);
          const x = gap + i * (barW + gap);
          const y = baseY - barH;

          const grad = ctx.createLinearGradient(0, y, 0, baseY);
          grad.addColorStop(0, colorTop);
          grad.addColorStop(1, colorBottom);
          ctx.fillStyle = grad;
          ctx.fillRect(x, y, barW, barH);
        }

        rafId = requestAnimationFrame(frame);
      }

      function start() {
        if (running) return;
        running = true;
        lastDraw = 0;
        rafId = requestAnimationFrame(frame);
      }

      function stop() {
        running = false;
        if (rafId) cancelAnimationFrame(rafId);
        rafId = 0;
      }

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) stop();
        else start();
      });

      start();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
