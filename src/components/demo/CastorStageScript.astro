---
import { castorGreetings } from '../../content/demo/castor-greetings';

interface Props {
  lang: 'en' | 'zh';
}

const { lang } = Astro.props;

const copy = {
  en: {
    placeholder: 'Ask Castor anything…',
    send: 'Send',
    sending: '…',
    clear: 'Clear conversation',
    counterFormat: (n: number) => `${n} / 20`,
    you: 'You',
    castor: 'Castor',
    error: 'Connection error. Try again?',
    rateLimited: 'Too many requests. Please wait a moment and try again.',
    tooLong: 'Message is too long (max 1000 characters).',
    sessionFull: 'Session limit reached. Clear the conversation to start over.',
  },
  zh: {
    placeholder: '问 Castor 任何问题…',
    send: '发送',
    sending: '…',
    clear: '清空对话',
    counterFormat: (n: number) => `${n} / 20`,
    you: '您',
    castor: 'Castor',
    error: '连接出错，请重试。',
    rateLimited: '请求太频繁了，稍等一下再试。',
    tooLong: '消息太长了（上限 1000 字符）。',
    sessionFull: '本次会话已达上限，请清空后重新开始。',
  },
}[lang];

const greeting = castorGreetings[lang];
---

<div class="castor-stage" data-lang={lang}>
  <div class="transcript-log" data-agent="castor">
    <div class="transcript-header" data-agent="castor">// CASTOR-CHAT-01 LOG ACTIVE</div>
    <div class="transcript-log__entries" id="castor-transcript" role="log" aria-live="polite"></div>
    <button
      class="transcript-log__new-indicator"
      id="castor-new-indicator"
      type="button"
      aria-label={lang === 'zh' ? '新消息' : 'New messages'}
    >↓ NEW</button>
    <div class="transcript-footer">_ SESSION ACTIVE _</div>
  </div>

  <div class="castor-stage__composer">
    <textarea
      id="castor-input"
      class="castor-stage__input"
      placeholder={copy.placeholder}
      rows="1"
      maxlength="1000"
      autocomplete="off"
    ></textarea>
    <button id="castor-send" class="castor-stage__send" type="button" aria-label={copy.send}>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="22" y1="2" x2="11" y2="13"></line>
        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
      </svg>
    </button>
  </div>

  <div class="castor-stage__meta">
    <button id="castor-clear" class="castor-stage__clear" type="button">{copy.clear}</button>
    <span id="castor-counter" class="castor-stage__counter">{copy.counterFormat(0)}</span>
  </div>
</div>

<script is:inline define:vars={{ lang, copy, greeting }}>
  (() => {
    const root = document.querySelector('.castor-stage');
    if (!root) return;

    const transcript = document.getElementById('castor-transcript');
    const input = document.getElementById('castor-input');
    const sendBtn = document.getElementById('castor-send');
    const clearBtn = document.getElementById('castor-clear');
    const counterEl = document.getElementById('castor-counter');
    if (!transcript || !input || !sendBtn || !clearBtn || !counterEl) return;

    const STORAGE_KEY = `infolead-castor-${lang}`;
    const MAX_USER_MESSAGES = 20;

    /** @type {{role: 'user'|'assistant', content: string}[]} */
    let history = [];

    // role: 'castor' | 'you' | 'error'
    function roleLabel(role) {
      return role === 'castor' ? 'CASTOR:' : role === 'you' ? 'YOU:' : 'ERROR';
    }

    function timestamp() {
      return new Date().toTimeString().slice(0, 8);
    }

    function appendLogEntry(role, content) {
      const entry = document.createElement('div');
      entry.className = 'log-entry';

      const tsEl = document.createElement('span');
      tsEl.className = 'log-timestamp';
      tsEl.textContent = `[${timestamp()}]`;

      const roleEl = document.createElement('span');
      roleEl.className = 'log-role';
      roleEl.dataset.role = role;
      roleEl.textContent = roleLabel(role);

      const contentEl = document.createElement('span');
      contentEl.className = 'log-content';
      contentEl.textContent = content;

      entry.appendChild(tsEl);
      entry.appendChild(roleEl);
      entry.appendChild(contentEl);
      transcript.appendChild(entry);
      transcript.scrollTop = transcript.scrollHeight;
      return { entry, contentEl };
    }

    // 5 user-friendly bilingual error messages (ZH · EN). Used when
    // /api/chat fails so silent failures become visible.
    const ERROR_MESSAGES = {
      empty:       '回复异常,请重试 · Response empty, please retry',
      timeout:     '响应超时,请检查网络 · Request timed out',
      http:        '服务暂时不可用 · Service temporarily unavailable',
      rateLimited: '请求过于频繁 · Too many requests, please slow down',
      parse:       '解析错误,请联系支持 · Parse error, please contact support',
    };

    function showError(entry, type, userMessagePreview) {
      const tsEl = entry.querySelector('.log-timestamp');
      if (tsEl) tsEl.textContent = `[${timestamp()}]`;
      const roleEl = entry.querySelector('.log-role');
      if (roleEl) {
        roleEl.dataset.role = 'error';
        roleEl.textContent = roleLabel('error');
      }
      const contentEl = entry.querySelector('.log-content');
      if (contentEl) contentEl.textContent = ERROR_MESSAGES[type] || ERROR_MESSAGES.parse;
      transcript.scrollTop = transcript.scrollHeight;
      // Telemetry: surfaces in Vercel Function logs for forensic review.
      console.error('castor_chat_error', {
        type,
        timestamp: new Date().toISOString(),
        user_message_preview: (userMessagePreview || '').slice(0, 30),
      });
    }

    function renderGreeting() {
      appendLogEntry('castor', greeting);
    }

    function load() {
      try {
        const raw = sessionStorage.getItem(STORAGE_KEY);
        if (raw) history = JSON.parse(raw);
      } catch {}
      // Greeting first (with current timestamp), then replay history.
      transcript.replaceChildren();
      renderGreeting();
      for (const m of history) {
        appendLogEntry(m.role === 'assistant' ? 'castor' : 'you', m.content);
      }
      updateCounter();
    }

    function save() {
      try { sessionStorage.setItem(STORAGE_KEY, JSON.stringify(history)); } catch {}
    }

    function updateCounter() {
      const n = history.filter((m) => m.role === 'user').length;
      counterEl.textContent = copy.counterFormat(n);
    }

    function setBusy(busy) {
      sendBtn.disabled = busy;
      input.disabled = busy;
      sendBtn.classList.toggle('is-busy', busy);
    }

    async function send() {
      const text = input.value.trim();
      if (!text) return;
      if (text.length > 1000) { alert(copy.tooLong); return; }

      const userCount = history.filter((m) => m.role === 'user').length;
      if (userCount >= MAX_USER_MESSAGES) { alert(copy.sessionFull); return; }

      history.push({ role: 'user', content: text });
      appendLogEntry('you', text);
      input.value = '';
      input.style.height = 'auto';
      updateCounter();
      save();
      setBusy(true);

      const { entry, contentEl } = appendLogEntry('castor', '');
      let acc = '';

      // 15s hard cap on total response time. AbortController fires when
      // backend (or network) takes too long — no spinning empty bubble.
      const ctrl = new AbortController();
      const timeoutId = setTimeout(() => ctrl.abort(), 15000);

      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: history, lang }),
          signal: ctrl.signal,
        });

        if (!res.ok || !res.body) {
          showError(entry, res.status === 429 ? 'rateLimited' : 'http', text);
          history.pop();
          updateCounter();
          save();
          return;
        }

        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          acc += decoder.decode(value, { stream: true });
          contentEl.textContent = acc;
          transcript.scrollTop = transcript.scrollHeight;
        }

        if (acc.trim()) {
          history.push({ role: 'assistant', content: acc });
          save();
        } else {
          showError(entry, 'empty', text);
          history.pop();
          updateCounter();
          save();
        }
      } catch (e) {
        const type = e && e.name === 'AbortError' ? 'timeout' : 'parse';
        showError(entry, type, text);
        history.pop();
        updateCounter();
        save();
      } finally {
        clearTimeout(timeoutId);
        setBusy(false);
        input.focus();
      }
    }

    function clearChat() {
      history = [];
      try { sessionStorage.removeItem(STORAGE_KEY); } catch {}
      transcript.replaceChildren();
      renderGreeting();
      updateCounter();
      input.focus();
    }

    input.addEventListener('input', () => {
      input.style.height = 'auto';
      input.style.height = Math.min(input.scrollHeight, 140) + 'px';
    });

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        send();
      }
    });

    sendBtn.addEventListener('click', send);
    clearBtn.addEventListener('click', clearChat);

    load();
  })();
</script>
