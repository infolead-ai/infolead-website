---
interface Props {
  lang: 'en' | 'zh';
}
const { lang } = Astro.props;

const copy = {
  en: {
    welcome: "Hi! I'm InfoLead's AI assistant. Ask me anything about our voice AI, websites, or AI video services.",
    placeholder: 'Ask me anything...',
    send: 'Send',
    clear: 'Clear chat',
  },
  zh: {
    welcome: '您好！我是 InfoLead 的 AI 客服。可以问我关于 AI 语音客服、网站开发、AI 视频营销的任何问题。',
    placeholder: '请输入您的问题...',
    send: '发送',
    clear: '清空对话',
  },
}[lang];
---

<div class="chat-demo" data-lang={lang}>
  <div class="chat-messages" id="chat-messages">
    <div class="chat-bubble assistant welcome">
      <div class="chat-bubble-content">{copy.welcome}</div>
    </div>
  </div>
  <div class="chat-input-area">
    <textarea
      id="chat-input"
      class="chat-input"
      placeholder={copy.placeholder}
      rows="1"
      maxlength="1000"
    ></textarea>
    <button id="chat-send" class="chat-send" type="button">{copy.send}</button>
  </div>
  <div class="chat-meta-row">
    <button id="chat-clear" class="chat-clear" type="button">{copy.clear}</button>
    <span class="chat-counter" id="chat-counter">0 / 20</span>
  </div>
</div>

<script>
  type Lang = 'en' | 'zh';
  type Msg = { role: 'user' | 'assistant'; content: string };

  const i18n = {
    en: {
      send: 'Send',
      sending: '...',
      error: 'Connection error. Try again?',
      rateLimited: 'Too many requests. Please wait a moment and try again.',
      tooLong: 'Message is too long (max 1000 characters).',
      sessionFull: 'Session limit reached. Clear the chat to start over.',
    },
    zh: {
      send: '发送',
      sending: '...',
      error: '连接出错，请重试。',
      rateLimited: '请求太频繁了，稍等一下再试。',
      tooLong: '消息太长了（上限 1000 字符）。',
      sessionFull: '本次会话已达上限，请清空对话后重新开始。',
    },
  };

  const MAX_USER_MESSAGES = 20;
  const root = document.querySelector('.chat-demo') as HTMLElement | null;
  if (root) {
    const lang = ((root.dataset.lang as Lang) || 'en') as Lang;
    const t = i18n[lang];
    const STORAGE_KEY = `infolead-chat-${lang}`;

    const messagesEl = document.getElementById('chat-messages')!;
    const inputEl = document.getElementById('chat-input') as HTMLTextAreaElement;
    const sendBtn = document.getElementById('chat-send') as HTMLButtonElement;
    const clearBtn = document.getElementById('chat-clear') as HTMLButtonElement;
    const counterEl = document.getElementById('chat-counter')!;

    let history: Msg[] = [];

    function load() {
      try {
        const raw = sessionStorage.getItem(STORAGE_KEY);
        if (raw) history = JSON.parse(raw) as Msg[];
      } catch {}
      renderHistory();
      updateCounter();
    }

    function save() {
      try { sessionStorage.setItem(STORAGE_KEY, JSON.stringify(history)); } catch {}
    }

    function renderHistory() {
      messagesEl.querySelectorAll('.chat-bubble:not(.welcome)').forEach((n) => n.remove());
      for (const m of history) appendBubble(m.role, m.content);
    }

    function appendBubble(role: 'user' | 'assistant', content: string): HTMLElement {
      const bubble = document.createElement('div');
      bubble.className = `chat-bubble ${role}`;
      const inner = document.createElement('div');
      inner.className = 'chat-bubble-content';
      inner.textContent = content;
      bubble.appendChild(inner);
      messagesEl.appendChild(bubble);
      messagesEl.scrollTop = messagesEl.scrollHeight;
      return inner;
    }

    function updateCounter() {
      const n = history.filter((m) => m.role === 'user').length;
      counterEl.textContent = `${n} / ${MAX_USER_MESSAGES}`;
    }

    function setBusy(busy: boolean) {
      sendBtn.disabled = busy;
      inputEl.disabled = busy;
      sendBtn.textContent = busy ? t.sending : t.send;
    }

    async function send() {
      const text = inputEl.value.trim();
      if (!text) return;
      if (text.length > 1000) { alert(t.tooLong); return; }

      const userCount = history.filter((m) => m.role === 'user').length;
      if (userCount >= MAX_USER_MESSAGES) { alert(t.sessionFull); return; }

      history.push({ role: 'user', content: text });
      appendBubble('user', text);
      inputEl.value = '';
      inputEl.style.height = 'auto';
      updateCounter();
      save();
      setBusy(true);

      const inner = appendBubble('assistant', '');
      let acc = '';

      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: history, lang }),
        });

        if (!res.ok || !res.body) {
          inner.textContent = res.status === 429 ? t.rateLimited : t.error;
          history.pop();
          updateCounter();
          save();
          return;
        }

        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          acc += decoder.decode(value, { stream: true });
          inner.textContent = acc;
          messagesEl.scrollTop = messagesEl.scrollHeight;
        }

        if (acc.trim()) {
          history.push({ role: 'assistant', content: acc });
          save();
        } else {
          inner.textContent = t.error;
          history.pop();
          updateCounter();
          save();
        }
      } catch {
        inner.textContent = t.error;
        history.pop();
        updateCounter();
        save();
      } finally {
        setBusy(false);
        inputEl.focus();
      }
    }

    function clearChat() {
      history = [];
      try { sessionStorage.removeItem(STORAGE_KEY); } catch {}
      renderHistory();
      updateCounter();
      inputEl.focus();
    }

    inputEl.addEventListener('input', () => {
      inputEl.style.height = 'auto';
      inputEl.style.height = Math.min(inputEl.scrollHeight, 120) + 'px';
    });

    inputEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        send();
      }
    });

    sendBtn.addEventListener('click', send);
    clearBtn.addEventListener('click', clearChat);

    load();
  }
</script>

<style>
  .chat-demo {
    max-width: 720px;
    margin: 0 auto;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(0, 229, 255, 0.18);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 0 50px rgba(0, 229, 255, 0.06), inset 0 0 40px rgba(0, 229, 255, 0.02);
  }

  .chat-messages {
    height: 480px;
    overflow-y: auto;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    background: linear-gradient(180deg, rgba(0,0,0,0.2), rgba(0,0,0,0.4));
  }

  .chat-bubble { display: flex; max-width: 88%; }
  .chat-bubble.assistant, .chat-bubble.welcome { align-self: flex-start; }
  .chat-bubble.user { align-self: flex-end; }

  .chat-bubble-content {
    padding: 12px 16px;
    border-radius: 14px;
    font-size: 14px;
    line-height: 1.65;
    white-space: pre-wrap;
    word-wrap: break-word;
    overflow-wrap: anywhere;
  }
  .chat-bubble.assistant .chat-bubble-content,
  .chat-bubble.welcome .chat-bubble-content {
    background: rgba(0, 229, 255, 0.05);
    border: 1px solid rgba(0, 229, 255, 0.18);
    color: rgba(255, 255, 255, 0.92);
  }
  .chat-bubble.user .chat-bubble-content {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #fff;
  }

  .chat-input-area {
    padding: 14px 16px;
    display: flex;
    gap: 10px;
    align-items: flex-end;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(0, 0, 0, 0.25);
  }
  .chat-input {
    flex: 1;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #fff;
    border-radius: 12px;
    padding: 10px 14px;
    font-size: 14px;
    font-family: inherit;
    line-height: 1.5;
    resize: none;
    outline: none;
    min-height: 42px;
    max-height: 120px;
  }
  .chat-input:focus { border-color: rgba(0, 229, 255, 0.45); box-shadow: 0 0 0 3px rgba(0, 229, 255, 0.08); }
  .chat-input:disabled { opacity: 0.5; }

  .chat-send {
    padding: 10px 22px;
    font-size: 14px;
    font-weight: 500;
    background: #00E5FF;
    color: #000;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    transition: 0.2s;
    box-shadow: 0 0 18px rgba(0, 229, 255, 0.25);
    white-space: nowrap;
  }
  .chat-send:hover:not(:disabled) { background: #33EEFF; box-shadow: 0 0 24px rgba(0, 229, 255, 0.45); }
  .chat-send:disabled { opacity: 0.5; cursor: not-allowed; box-shadow: none; }

  .chat-meta-row {
    padding: 8px 18px 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: monospace;
    font-size: 10px;
    color: rgba(255, 255, 255, 0.4);
    background: rgba(0, 0, 0, 0.3);
    letter-spacing: 0.05em;
  }
  .chat-clear {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.45);
    cursor: pointer;
    font-family: monospace;
    font-size: 10px;
    padding: 0;
    text-decoration: underline;
    text-underline-offset: 2px;
    letter-spacing: 0.05em;
  }
  .chat-clear:hover { color: #00E5FF; }
</style>
