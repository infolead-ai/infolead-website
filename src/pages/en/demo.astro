---
import Layout from '../../layouts/Layout.astro';
import TeamMemberCard from '../../components/demo/TeamMemberCard.astro';
import { team } from '../../data/ai-team';

export const prerender = true;
---

<Layout lang="en" title="AI Specialist Team — InfoLead AI">
  <section class="team-chooser">
    <div class="team-chooser__hero">
      <div class="team-chooser__eyebrow">
        <span class="team-chooser__eyebrow-dot" aria-hidden="true"></span>
        AI SPECIALIST TEAM
      </div>
      <h1 class="team-chooser__title">
        Meet the team
        <span class="grad">behind your demo.</span>
      </h1>
      <p class="team-chooser__subtitle">
        Each specialist is a portfolio piece — built, tuned, and live on this site.
        Pick the one whose voice you'd like to hear today.
      </p>
    </div>

    <div class="team-chooser__grid">
      {team.map((member) => (
        <TeamMemberCard member={member} lang="en" />
      ))}
    </div>

    <p class="team-chooser__disclaimer">
      DEMO ONLY · RESPONSES DO NOT CONSTITUTE FORMAL SERVICE COMMITMENTS
    </p>
  </section>
</Layout>

<style>
  .team-chooser {
    max-width: 1080px;
    margin: 0 auto;
    padding: 64px 24px 80px;
  }
  .team-chooser__hero {
    text-align: center;
    margin-bottom: 56px;
  }
  .team-chooser__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.3em;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 28px;
  }
  .team-chooser__eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #00E5FF;
    box-shadow: 0 0 12px rgba(0, 229, 255, 0.8);
  }
  .team-chooser__title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0 0 20px;
  }
  .team-chooser__title .grad {
    display: block;
    background: linear-gradient(90deg, #fff, #00E5FF);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  .team-chooser__subtitle {
    font-size: 17px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.6);
    max-width: 600px;
    margin: 0 auto;
    font-weight: 300;
  }
  .team-chooser__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px;
    max-width: 880px;
    margin: 0 auto;
  }
  .team-chooser__disclaimer {
    text-align: center;
    margin-top: 48px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10.5px;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.3);
  }

  @media (max-width: 640px) {
    .team-chooser { padding: 40px 16px 56px; }
    .team-chooser__hero { margin-bottom: 36px; }
    .team-chooser__eyebrow { font-size: 10px; padding: 6px 12px; margin-bottom: 22px; }
    .team-chooser__subtitle { font-size: 15px; }
    .team-chooser__grid { gap: 18px; }
  }
</style>
