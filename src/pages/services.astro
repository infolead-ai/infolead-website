---
import Layout from '../layouts/Layout.astro';
import { services } from '../data/services';
---

<Layout title="Services — InfoLead AI Solutions">
  <section style="padding: 120px 0;">
    <h1 class="italic" style="font-size: 4rem; margin-bottom: 80px;">Solutions & Expertise</h1>
    <div>
      {services.map((s) => (
        <div id={s.id} style="margin-bottom: 120px; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 80px;">
          <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 30px;">
            <span style="color: #00E5FF; font-family: monospace; font-size: 1.5rem;">{s.id}</span>
            <h2 style="font-size: 2.5rem;">{s.title}</h2>
          </div>
          <p style="font-size: 1.4rem; color: #F5F7FA; margin-bottom: 20px;">{s.zhDesc}</p>
          <p style="font-size: 1.1rem; color: rgba(255,255,255,0.5); max-width: 800px; margin-bottom: 40px;">{s.desc}</p>
          <div style="display: flex; gap: 12px; flex-wrap: wrap;">
            {s.features.map(f => (
              <span style="background: rgba(0, 229, 255, 0.05); border: 1px solid rgba(0, 229, 255, 0.2); padding: 8px 20px; border-radius: 99px; font-size: 12px; color: #00E5FF;">{f}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>