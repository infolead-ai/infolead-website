---
import Layout from '../../layouts/Layout.astro';

export const prerender = true;
---

<Layout lang="zh" title="质量标准 — InfoLead 品控协议">

  <!-- HERO -->
  <section style="padding: 80px 0 60px; text-align: center;">
    <div style="display: inline-flex; align-items: center; gap: 12px; font-family: monospace; font-size: 11px; letter-spacing: 0.3em; color: rgba(255, 255, 255, 0.4); background: rgba(255, 255, 255, 0.03); padding: 8px 16px; border-radius: 999px; border: 1px solid rgba(255, 255, 255, 0.06); margin-bottom: 32px;">
      <span style="width: 6px; height: 6px; border-radius: 50%; background: #00E5FF; box-shadow: 0 0 12px rgba(0, 229, 255, 0.8);"></span>
      AI · 认证 · 多伦多 · 加拿大
    </div>
    <h1 style="font-size: clamp(2.8rem, 6.5vw, 4.2rem); font-weight: 300; line-height: 1.05; margin-bottom: 24px; letter-spacing: -0.03em;">
      InfoLead <span class="grad">质量标准</span>
    </h1>
    <p style="font-size: 18px; color: rgba(255,255,255,0.6); max-width: 560px; margin: 0 auto; line-height: 1.6; font-weight: 300;">
      每次部署。每次更新。每位客户。
    </p>
  </section>

  <!-- SECTION 1: The Number -->
  <section style="padding: 60px 0 80px; text-align: center; border-top: 1px solid rgba(255,255,255,0.06); border-bottom: 1px solid rgba(255,255,255,0.06);">
    <div style="font-family: 'Instrument Serif', serif; font-style: italic; font-size: clamp(8rem, 22vw, 16rem); color: #00E5FF; line-height: 0.9; text-shadow: 0 0 60px rgba(0,229,255,0.25); margin-bottom: 16px;">17</div>
    <div style="font-family: monospace; font-size: 11px; letter-spacing: 0.25em; color: rgba(255,255,255,0.5); margin-bottom: 40px;">每次部署前的自动化质量验收测试</div>
    <p style="font-size: 17px; color: rgba(255,255,255,0.65); max-width: 540px; margin: 0 auto; line-height: 1.7; font-weight: 300;">
      每一套 InfoLead AI 系统在正式交付前，<br/>
      <span style="color: #fff;">都须通过 17 项自动化质量验收测试。</span>
    </p>
  </section>

  <!-- SECTION 2: Four Categories -->
  <section style="padding: 100px 0;">
    <h2 style="font-family: 'Instrument Serif', serif; font-style: italic; font-size: clamp(2.2rem, 5vw, 3.2rem); font-weight: 400; margin-bottom: 60px; text-align: center;">四大信任支柱</h2>
    <div class="standards-grid">

      <div class="standard-card" style="border-top-color: #FF5050;">
        <div class="standard-icon">🛡️</div>
        <div class="standard-eyebrow" style="color: #FF5050;">SECURITY · 安全性</div>
        <h3>安全性</h3>
        <ul>
          <li>提示词注入攻击防护</li>
          <li>系统配置保密性</li>
          <li>AI 身份保护机制</li>
          <li>对抗性输入处理</li>
        </ul>
      </div>

      <div class="standard-card" style="border-top-color: #FF9500;">
        <div class="standard-icon">🎯</div>
        <div class="standard-eyebrow" style="color: #FF9500;">ACCURACY · 准确性</div>
        <h3>准确性</h3>
        <ul>
          <li>禁止编造数据和统计数字</li>
          <li>禁止虚构客户案例</li>
          <li>禁止声称未确认的集成功能</li>
          <li>诚实表达能力边界</li>
        </ul>
      </div>

      <div class="standard-card" style="border-top-color: #34C759;">
        <div class="standard-icon">✓</div>
        <div class="standard-eyebrow" style="color: #34C759;">COMPLIANCE · 合规性</div>
        <h3>合规性</h3>
        <ul>
          <li>价格管控机制已启用</li>
          <li>禁止确认用户提出的具体价格</li>
          <li>品牌安全回复保障</li>
        </ul>
      </div>

      <div class="standard-card" style="border-top-color: #00E5FF;">
        <div class="standard-icon">⚡</div>
        <div class="standard-eyebrow" style="color: #00E5FF;">RESILIENCE · 健壮性</div>
        <h3>健壮性</h3>
        <ul>
          <li>限速保护（每 IP 每分钟 10 次）</li>
          <li>消息长度限制（1000 字符）</li>
          <li>会话上限（20 条消息）</li>
          <li>异常输入处理</li>
          <li>跑题重定向机制</li>
          <li>空白输入拦截</li>
        </ul>
      </div>

    </div>
  </section>

  <!-- SECTION 3: Real Story -->
  <section style="padding: 60px 0 100px;">
    <div class="real-story">
      <div class="real-story-eyebrow">案例档案 · 2026-04-26</div>
      <h2>我们在自己的 demo 里发现了 3 个严重问题。</h2>
      <p style="margin-bottom: 28px;">
        在向公众开放 AI demo 之前，我们跑了完整的质量检测流程，发现了：
      </p>

      <div class="finding">
        <div class="finding-tag" style="color: #FF5050;">🔴 P0 — 提示词注入漏洞</div>
        <p>用户可以让 AI 泄露完整的系统配置。<strong>上线前已修复。</strong></p>
      </div>

      <div class="finding">
        <div class="finding-tag" style="color: #FF9500;">🟠 P1 — 数据编造</div>
        <p>AI 虚构了一个客户案例和"节省 60% 成本"的统计数字。<strong>两者均已移除。</strong></p>
      </div>

      <div class="finding">
        <div class="finding-tag" style="color: #FF9500;">🟠 P1 — 虚假客户引用</div>
        <p>AI 声称已有律所合作案例，实际并不存在。<strong>防护规则已添加。</strong></p>
      </div>

      <p style="margin-top: 32px; font-size: 15px; color: rgba(255,255,255,0.55);">
        三个问题全部修复。重跑 17 项测试确认生效。然后才开放 demo。
      </p>
    </div>
  </section>

  <!-- SECTION 4: Promise -->
  <section style="padding: 80px 0 60px; text-align: center;">
    <div style="font-family: 'Instrument Serif', serif; font-style: italic; font-size: clamp(2.8rem, 7vw, 5rem); line-height: 1.05; letter-spacing: -0.02em;">
      <div style="color: rgba(255,255,255,0.5);">修好了，</div>
      <div class="grad" style="margin-top: 8px;">才交付。</div>
    </div>
    <div style="margin-top: 56px; font-family: monospace; font-size: 12px; letter-spacing: 0.15em; color: rgba(255,255,255,0.4); line-height: 1.8;">
      — GLEN TANG，创始人<br/>
      &nbsp;&nbsp;INFOLEAD TECHNOLOGY INC.
    </div>
  </section>

  <!-- CTA -->
  <section style="padding: 40px 0 100px; text-align: center;">
    <div class="flex gap-5 flex-wrap" style="justify-content: center;">
      <a href="/zh/demo" class="btn btn-primary" style="padding: 16px 36px; font-size: 15px;">体验 AI Demo →</a>
      <a href="mailto:hello@infolead.ca" class="btn btn-ghost" style="padding: 16px 36px; font-size: 15px;">预约策略咨询 →</a>
    </div>
  </section>

</Layout>

<style>
  .standards-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
  }
  @media (max-width: 720px) {
    .standards-grid { grid-template-columns: 1fr; gap: 20px; }
  }

  .standard-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-top: 3px solid;
    border-radius: 18px;
    padding: 36px 30px;
    transition: 0.3s;
  }
  .standard-card:hover {
    background: rgba(255, 255, 255, 0.04);
    transform: translateY(-3px);
  }
  .standard-icon {
    font-size: 32px;
    margin-bottom: 16px;
    line-height: 1;
  }
  .standard-eyebrow {
    font-family: monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    margin-bottom: 12px;
  }
  .standard-card h3 {
    font-size: 24px;
    font-weight: 500;
    margin: 0 0 20px 0;
    color: #fff;
  }
  .standard-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
    color: rgba(255,255,255,0.65);
    font-size: 14px;
    line-height: 2;
  }
  .standard-card li::before {
    content: "→";
    color: rgba(255,255,255,0.3);
    margin-right: 10px;
  }

  .real-story {
    background: linear-gradient(135deg, rgba(0, 0, 0, 0.5), rgba(10, 14, 26, 0.7));
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-left: 3px solid #00E5FF;
    border-radius: 0 18px 18px 0;
    padding: 48px 44px;
    max-width: 840px;
    margin: 0 auto;
  }
  @media (max-width: 720px) {
    .real-story { padding: 32px 24px; }
  }
  .real-story-eyebrow {
    font-family: monospace;
    font-size: 11px;
    letter-spacing: 0.25em;
    color: rgba(0, 229, 255, 0.7);
    margin-bottom: 20px;
  }
  .real-story h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    font-weight: 500;
    margin: 0 0 28px 0;
    line-height: 1.25;
    color: #fff;
  }
  .real-story p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 15.5px;
    line-height: 1.75;
    margin: 0 0 16px 0;
  }
  .finding {
    margin: 28px 0;
    padding-left: 16px;
    border-left: 2px solid rgba(255, 255, 255, 0.08);
  }
  .finding-tag {
    font-family: monospace;
    font-size: 12.5px;
    letter-spacing: 0.05em;
    margin-bottom: 6px;
    font-weight: 600;
  }
  .finding p {
    margin: 4px 0 0 0;
    font-size: 15px;
  }
  .finding strong { color: #34C759; font-weight: 500; }
  .real-story p, .finding p { font-family: 'JetBrains Mono', 'IBM Plex Mono', ui-monospace, monospace; font-size: 14px; }
</style>
