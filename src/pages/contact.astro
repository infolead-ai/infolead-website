---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — InfoLead Technology">
  <section style="padding: 120px 0; max-width: 800px; margin: 0 auto;">
    <div class="tag" style="margin-bottom: 40px; display: inline-flex; align-items: center; gap: 12px; font-family: monospace; font-size: 11px; letter-spacing: 0.3em; color: rgba(255, 255, 255, 0.4); background: rgba(255, 255, 255, 0.03); padding: 8px 16px; border-radius: 999px; border: 1px solid rgba(255, 255, 255, 0.06);">
      <span class="dot" style="width: 6px; height: 6px; border-radius: 50%; background: #00E5FF; box-shadow: 0 0 12px rgba(0, 229, 255, 0.8);"></span>
      LET'S TALK
    </div>
    
    <h1 class="italic" style="font-size: clamp(3rem, 6vw, 4.5rem); margin-bottom: 24px; line-height: 1;">
      Book a Demo.
    </h1>
    
    <p style="font-size: 1.25rem; color: rgba(255,255,255,0.6); margin-bottom: 60px; line-height: 1.6;">
      Ready to transform your business with AI? Drop us a line and we will get back to you within 24 hours to schedule a tailored demonstration.
    </p>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; margin-bottom: 60px;">
      
      <a href="mailto:hello@infolead.ca" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); padding: 40px; border-radius: 20px; text-decoration: none; color: inherit; transition: 0.3s;" onmouseover="this.style.borderColor='rgba(0,229,255,0.4)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.06)'">
        <div style="color: #00E5FF; font-family: monospace; font-size: 12px; margin-bottom: 16px; letter-spacing: 0.1em;">EMAIL US</div>
        <div style="font-size: 20px; font-weight: 500;">hello@infolead.ca</div>
        <div style="font-size: 14px; color: rgba(255,255,255,0.5); margin-top: 8px;">For demos & general inquiries</div>
      </a>
      
      <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); padding: 40px; border-radius: 20px;">
        <div style="color: #00E5FF; font-family: monospace; font-size: 12px; margin-bottom: 16px; letter-spacing: 0.1em;">LOCATION</div>
        <div style="font-size: 20px; font-weight: 500;">Toronto, Canada</div>
        <div style="font-size: 14px; color: rgba(255,255,255,0.5); margin-top: 8px;">Serving North American SMBs</div>
      </div>

    </div>
  </section>
</Layout>