# OpenRouter — backend key for /api/chat (Castor text demo)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ElevenLabs Lyra voice agent — public agent ID, safe to expose to client.
# Security is enforced by ElevenLabs Dashboard allowlist + frontend allowlist in
# src/lib/lyra-allowlist.ts. PUBLIC_ prefix is required so Astro exposes it to the browser.
PUBLIC_LYRA_AGENT_ID=agent_xxxxxxxxxxxxxxxxxxxxxx
